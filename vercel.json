{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/mcp.ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 10 * * 0"
    }
  ]
}
